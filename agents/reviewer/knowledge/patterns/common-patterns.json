{
  "version": "2.0.0",
  "description": "Claude Code 组件常用设计模式库（扩展版）",
  "last_updated": "2026-03-12",
  "patterns": [
    {
      "id": "DP001",
      "name": "Explore-Plan-Execute",
      "category": "workflow",
      "description": "复杂任务分解模式：先探索理解问题，再制定计划，最后执行验证",
      "applicable": ["skill", "subagent"],
      "structure": {
        "explore": "理解问题和上下文，收集必要信息",
        "plan": "制定详细的执行计划，分解步骤",
        "execute": "按计划执行，验证结果"
      },
      "benefits": [
        "降低复杂任务的失败率",
        "提供清晰的执行路径",
        "便于调试和优化"
      ],
      "example": {
        "scenario": "代码重构任务",
        "implementation": "1. 探索：分析现有代码结构\n2. 计划：制定重构方案\n3. 执行：逐步重构并测试"
      }
    },
    {
      "id": "DP002",
      "name": "Pre-Check-Action-Verify",
      "category": "workflow",
      "description": "安全操作模式：执行前检查条件，执行操作，执行后验证结果",
      "applicable": ["skill", "command"],
      "structure": {
        "pre_check": "检查前置条件（权限、依赖、状态）",
        "action": "执行核心操作",
        "verify": "验证结果是否符合预期"
      },
      "benefits": [
        "避免破坏性操作",
        "提供清晰的错误信息",
        "确保操作的原子性"
      ],
      "example": {
        "scenario": "文件删除操作",
        "implementation": "1. 检查：文件是否存在，是否有权限\n2. 操作：删除文件\n3. 验证：确认文件已删除"
      }
    },
    {
      "id": "DP003",
      "name": "Template-Fill-Validate",
      "category": "generation",
      "description": "内容生成模式：使用模板，填充数据，验证输出",
      "applicable": ["skill"],
      "structure": {
        "template": "定义内容模板",
        "fill": "填充动态数据",
        "validate": "验证生成的内容"
      },
      "benefits": [
        "保证输出格式一致",
        "减少错误",
        "便于维护"
      ],
      "example": {
        "scenario": "文档生成",
        "implementation": "1. 模板：Markdown 文档模板\n2. 填充：插入项目信息\n3. 验证：检查格式和完整性"
      }
    },
    {
      "id": "DP004",
      "name": "Resume-Continue Pattern",
      "category": "subagent-advanced",
      "description": "SubAgent恢复模式：保存执行状态，支持中断后恢复继续执行",
      "applicable": ["subagent"],
      "structure": {
        "checkpoint": "定期保存执行状态和上下文",
        "resume": "从checkpoint恢复，继续执行",
        "deduplication": "避免重复执行已完成的步骤"
      },
      "benefits": [
        "提高长时间任务的鲁棒性",
        "节省token，避免重复工作",
        "支持分批执行大型任务"
      ],
      "configuration": {
        "resume": "agent-id",
        "max_turns": "建议设置合理上限"
      },
      "example": {
        "scenario": "大型代码审查任务",
        "implementation": "1. 审查前50个文件后保存状态\n2. 使用resume参数继续审查剩余文件\n3. 避免重复审查已完成的文件"
      },
      "related_antipatterns": ["SUB-013"]
    },
    {
      "id": "DP005",
      "name": "Parallel-Subagent Pattern",
      "category": "subagent-advanced",
      "description": "并行SubAgent模式：同时调度多个SubAgent处理独立任务",
      "applicable": ["skill", "subagent"],
      "structure": {
        "task_split": "将大任务拆分为独立子任务",
        "parallel_dispatch": "并行调度多个SubAgent",
        "result_aggregate": "收集并合并所有结果"
      },
      "benefits": [
        "显著提升执行效率",
        "充分利用并发能力",
        "适合处理大规模数据"
      ],
      "configuration": {
        "method": "单个消息中发送多个Task tool调用"
      },
      "example": {
        "scenario": "多文件批量处理",
        "implementation": "1. 拆分：将100个文件分为5组\n2. 并行：同时调度5个review-core处理各组\n3. 聚合：合并所有审查报告"
      },
      "related_antipatterns": ["ARCH-013"]
    },
    {
      "id": "DP006",
      "name": "Max-Turns Boundary Pattern",
      "category": "subagent-advanced",
      "description": "SubAgent轮次限制模式：设置最大轮次防止无限循环",
      "applicable": ["subagent"],
      "structure": {
        "estimate": "估算任务所需轮次",
        "set_limit": "设置max_turns上限",
        "fallback": "达到上限时的降级策略"
      },
      "benefits": [
        "防止token耗尽",
        "避免无限循环",
        "确保任务可控"
      ],
      "configuration": {
        "max_turns": "9（默认最大值）",
        "typical_values": "简单任务3-5，复杂任务7-9"
      },
      "example": {
        "scenario": "迭代式设计任务",
        "implementation": "1. 估算：设计通常需要5轮迭代\n2. 设置：max_turns=7（留2轮buffer）\n3. 降级：7轮后输出当前最佳方案"
      },
      "related_antipatterns": ["SUB-011"]
    },
    {
      "id": "DP007",
      "name": "Skills-Preload Pattern",
      "category": "subagent-advanced",
      "description": "知识预加载模式：SubAgent通过skills字段预加载专业知识",
      "applicable": ["subagent"],
      "structure": {
        "identify": "识别SubAgent需要的专业知识",
        "declare": "在skills字段声明lib-* Skills",
        "utilize": "SubAgent自动加载并使用知识"
      },
      "benefits": [
        "提供专业领域知识",
        "提高任务准确性",
        "减少上下文传递"
      ],
      "configuration": {
        "skills": ["plugin:lib-antipatterns", "plugin:std-naming-rules"]
      },
      "example": {
        "scenario": "代码审查SubAgent",
        "implementation": "skills:\n  - ccc:lib-antipatterns\n  - ccc:std-naming-rules\n自动加载76+反模式规则和命名规范"
      },
      "related_antipatterns": ["SUB-014"]
    },
    {
      "id": "DP008",
      "name": "Hook-PreToolUse Pattern",
      "category": "hook-events",
      "description": "工具调用前检查模式：在工具执行前验证权限和参数",
      "applicable": ["hook"],
      "structure": {
        "validate": "验证工具调用的合法性",
        "check_permission": "检查权限和环境变量",
        "block_or_allow": "决定是否允许执行"
      },
      "benefits": [
        "防止危险操作",
        "确保权限合规",
        "提供安全边界"
      ],
      "configuration": {
        "event": "PreToolUse",
        "tools": ["Bash", "Write", "Edit"]
      },
      "example": {
        "scenario": "禁止在生产环境执行rm -rf",
        "implementation": "hooks/pre-deploy-check.sh\n检测Bash命令中的危险操作\n如检测到则block并提示"
      },
      "related_antipatterns": ["HOOK-001", "PERM-001"]
    },
    {
      "id": "DP009",
      "name": "Hook-PostToolUse Pattern",
      "category": "hook-events",
      "description": "工具调用后验证模式：在工具执行后验证结果和副作用",
      "applicable": ["hook"],
      "structure": {
        "capture_result": "捕获工具执行结果",
        "verify": "验证结果符合预期",
        "notify": "通知用户或触发后续操作"
      },
      "benefits": [
        "确保操作成功",
        "检测异常情况",
        "支持审计日志"
      ],
      "configuration": {
        "event": "PostToolUse",
        "tools": ["Bash", "Write"]
      },
      "example": {
        "scenario": "Git提交后自动推送",
        "implementation": "hooks/post-commit-push.sh\n检测git commit成功\n自动执行git push"
      },
      "related_antipatterns": ["HOOK-001", "HOOK-007"]
    },
    {
      "id": "DP010",
      "name": "Hook-Notification Pattern",
      "category": "hook-events",
      "description": "通知模式：接收Claude Code的系统通知",
      "applicable": ["hook"],
      "structure": {
        "subscribe": "订阅特定类型的通知",
        "handle": "处理通知内容",
        "action": "执行相应操作"
      },
      "benefits": [
        "集成外部系统",
        "自动化工作流",
        "提供实时反馈"
      ],
      "configuration": {
        "event": "Notification",
        "types": ["error", "completion", "warning"]
      },
      "example": {
        "scenario": "任务完成后发送Slack通知",
        "implementation": "hooks/notify-slack.sh\n接收completion通知\n调用Slack webhook发送消息"
      },
      "related_antipatterns": ["HOOK-001"]
    },
    {
      "id": "DP011",
      "name": "Hook-Once Pattern",
      "category": "hook-events",
      "description": "单次执行模式：Hook仅执行一次后自动禁用",
      "applicable": ["hook"],
      "structure": {
        "trigger": "首次触发时执行",
        "disable": "执行后自动禁用",
        "cleanup": "清理临时状态"
      },
      "benefits": [
        "避免重复执行",
        "适合一次性操作",
        "节省资源"
      ],
      "configuration": {
        "once": true
      },
      "example": {
        "scenario": "首次启动时初始化配置",
        "implementation": "hooks/init-config.sh\nonce: true\n首次启动时创建配置文件"
      },
      "related_antipatterns": ["HOOK-012"]
    },
    {
      "id": "DP012",
      "name": "MCP-HTTP-Transport Pattern",
      "category": "mcp-transport",
      "description": "HTTP传输模式：使用HTTP协议连接MCP服务器（推荐）",
      "applicable": ["mcp"],
      "structure": {
        "configure": "配置HTTP端点和认证",
        "connect": "通过HTTP连接远程服务器",
        "scale": "支持水平扩展和负载均衡"
      },
      "benefits": [
        "支持远程部署",
        "易于扩展和负载均衡",
        "标准HTTP协议，兼容性好"
      ],
      "configuration": {
        "transport": "http",
        "url": "https://api.example.com/mcp",
        "auth": "Bearer token"
      },
      "example": {
        "scenario": "连接远程GitHub MCP服务器",
        "implementation": ".mcp.json:\n{\n  \"mcpServers\": {\n    \"github\": {\n      \"transport\": \"http\",\n      \"url\": \"https://mcp.github.com\",\n      \"env\": {\"TOKEN\": \"${GITHUB_TOKEN}\"}\n    }\n  }\n}"
      },
      "official_reference": "mcp.md - 推荐使用http传输",
      "related_antipatterns": ["MCP-001", "MCP-009"]
    },
    {
      "id": "DP013",
      "name": "MCP-Stdio-Transport Pattern",
      "category": "mcp-transport",
      "description": "Stdio传输模式：使用标准输入输出连接本地MCP服务器",
      "applicable": ["mcp"],
      "structure": {
        "spawn": "启动本地进程",
        "communicate": "通过stdin/stdout通信",
        "manage": "管理进程生命周期"
      },
      "benefits": [
        "适合本地进程通信",
        "无需网络配置",
        "进程隔离性好"
      ],
      "configuration": {
        "command": "mcp-server-binary",
        "args": ["--stdio"],
        "transport": "stdio"
      },
      "example": {
        "scenario": "连接本地文件系统MCP服务器",
        "implementation": ".mcp.json:\n{\n  \"mcpServers\": {\n    \"filesystem\": {\n      \"command\": \"mcp-server-filesystem\",\n      \"args\": [\"--stdio\", \"--root\", \"${PROJECT_DIR}\"],\n      \"env\": {\"PROJECT_DIR\": \"/path/to/project\"}\n    }\n  }\n}"
      },
      "official_reference": "mcp.md - stdio适用于本地进程",
      "related_antipatterns": ["MCP-001"]
    },
    {
      "id": "DP014",
      "name": "Subagent-Hooks Integration Pattern",
      "category": "subagent-advanced",
      "description": "SubAgent与Hooks集成模式：SubAgent运行时启用特定Hooks",
      "applicable": ["subagent"],
      "structure": {
        "define_hooks": "定义SubAgent专用的Hooks",
        "enable": "SubAgent启动时启用Hooks",
        "scope": "Hooks仅在SubAgent上下文生效"
      },
      "benefits": [
        "提供SubAgent级别的权限控制",
        "支持细粒度的行为定制",
        "隔离不同SubAgent的策略"
      ],
      "configuration": {
        "hooks": ["pre-tool-validation.sh", "post-result-verify.sh"]
      },
      "example": {
        "scenario": "审查SubAgent禁止修改代码",
        "implementation": "review-core/SKILL.md:\nhooks:\n  - plugin:ccc:hooks/block-write-tools.sh\n阻止使用Write/Edit工具"
      },
      "related_antipatterns": ["SUB-015"]
    },
    {
      "id": "DP015",
      "name": "Context-Fork Pattern",
      "category": "subagent-advanced",
      "description": "上下文隔离模式：SubAgent使用fork模式隔离上下文",
      "applicable": ["subagent"],
      "structure": {
        "fork": "创建独立的上下文",
        "isolate": "隔离工具和状态",
        "cleanup": "完成后清理上下文"
      },
      "benefits": [
        "避免污染主上下文",
        "支持并行执行",
        "提高安全性"
      ],
      "configuration": {
        "context": "fork"
      },
      "example": {
        "scenario": "并行审查多个文件",
        "implementation": "context: fork\n每个审查SubAgent独立上下文\n互不干扰，可并行执行"
      },
      "related_antipatterns": ["SUB-003"]
    }
  ]
}
