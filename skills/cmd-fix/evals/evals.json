{
  "version": "1.0",
  "skill": "cmd-fix",
  "description": "测试问题修复流程的准确性和效率",
  "evals": [
    {
      "name": "single_issue_fix",
      "description": "单一问题修复：修复审查报告中的单个问题",
      "input": {
        "review_report": "test-fixtures/review-report-single-issue.md",
        "issue_id": "TEST-001",
        "mode": "interactive"
      },
      "expected_output": {
        "modifications": {
          "files_changed": 1,
          "contains_fix": true
        },
        "validation": {
          "issue_resolved": true,
          "no_regression": true,
          "fix_documented": true
        }
      },
      "timeout": 120,
      "priority": "critical",
      "tags": ["fix", "single", "basic"]
    },
    {
      "name": "batch_fix",
      "description": "批量修复：同时修复多个相关问题",
      "input": {
        "review_report": "test-fixtures/review-report-multiple-issues.md",
        "priority": "P0",
        "mode": "batch"
      },
      "expected_output": {
        "modifications": {
          "files_changed": 3,
          "issues_fixed": 5,
          "fix_summary": true
        },
        "validation": {
          "all_p0_resolved": true,
          "no_conflicts": true,
          "tests_pass": true
        }
      },
      "timeout": 300,
      "priority": "high",
      "tags": ["fix", "batch", "p0"]
    },
    {
      "name": "evals_creation_fix",
      "description": "测试定义修复：为缺少evals.json的组件创建测试",
      "input": {
        "review_report": "test-fixtures/review-report-missing-evals.md",
        "issue_id": "TEST-001",
        "component": "test-fixtures/skill-without-evals"
      },
      "expected_output": {
        "new_files": [
          {
            "path": "evals/evals.json",
            "valid_json": true,
            "contains_fields": [
              "version",
              "skill",
              "evals",
              "success_criteria"
            ]
          }
        ],
        "validation": {
          "test_cases_defined": true,
          "fixtures_referenced": true,
          "schema_valid": true
        }
      },
      "timeout": 180,
      "priority": "high",
      "tags": ["fix", "testability", "evals"]
    },
    {
      "name": "plugin_manifest_fix",
      "description": "Plugin配置修复：修复plugin.json格式错误",
      "input": {
        "review_report": "test-fixtures/review-report-plugin-manifest.md",
        "issue_id": "PLUGIN-001",
        "target": "test-fixtures/plugin-with-invalid-manifest"
      },
      "expected_output": {
        "modifications": {
          "file": ".claude-plugin/plugin.json",
          "unknown_fields_removed": true,
          "types_corrected": true,
          "whitelist_compliant": true
        },
        "validation": {
          "valid_json": true,
          "schema_compliant": true,
          "no_unknown_fields": true
        }
      },
      "timeout": 60,
      "priority": "critical",
      "tags": ["fix", "plugin", "manifest", "p0"]
    },
    {
      "name": "circular_dependency_fix",
      "description": "循环依赖修复：解除组件间的循环依赖",
      "input": {
        "review_report": "test-fixtures/review-report-circular-dep.md",
        "issue_id": "LOOP-001",
        "components": ["fix-orchestrator", "review-core"]
      },
      "expected_output": {
        "refactoring": {
          "dependencies_reorganized": true,
          "circular_removed": true,
          "one_way_flow": true
        },
        "validation": {
          "no_circular_deps": true,
          "functionality_preserved": true,
          "tests_pass": true
        }
      },
      "timeout": 240,
      "priority": "high",
      "tags": ["fix", "architecture", "refactoring"]
    }
  ],
  "test_fixtures": {
    "review_reports": [
      {
        "name": "single-issue",
        "file": "test-fixtures/review-report-single-issue.md",
        "issues": ["TEST-001"]
      },
      {
        "name": "multiple-issues",
        "file": "test-fixtures/review-report-multiple-issues.md",
        "issues": ["TEST-001", "SEC-001", "SCALE-001", "CFG-001", "DOC-001"]
      },
      {
        "name": "missing-evals",
        "file": "test-fixtures/review-report-missing-evals.md",
        "issues": ["TEST-001"]
      },
      {
        "name": "plugin-manifest",
        "file": "test-fixtures/review-report-plugin-manifest.md",
        "issues": ["PLUGIN-001"]
      },
      {
        "name": "circular-dep",
        "file": "test-fixtures/review-report-circular-dep.md",
        "issues": ["LOOP-001"]
      }
    ],
    "components": [
      {
        "name": "skill-without-evals",
        "dir": "test-fixtures/skill-without-evals"
      },
      {
        "name": "plugin-with-invalid-manifest",
        "dir": "test-fixtures/plugin-with-invalid-manifest"
      }
    ]
  },
  "success_criteria": {
    "pass_rate": 0.8,
    "critical_pass_rate": 1.0,
    "max_avg_duration": 180,
    "fix_accuracy": 0.95,
    "no_regression_rate": 1.0
  }
}
