{
  "name": "cmd-diff-evals",
  "version": "1.0.0",
  "description": "测试用例：对比两个制品版本的差异",
  "test_cases": [
    {
      "id": "normal-001",
      "name": "正常场景：Blueprint 版本对比",
      "description": "验证 Blueprint 差异检测",
      "input": {
        "arguments": "--from=BLP-001 --to=BLP-002"
      },
      "expected_behavior": {
        "detects_added_elements": true,
        "detects_modified_elements": true,
        "detects_removed_elements": true,
        "generates_report": "docs/ccc/diffs/*-diff.md"
      },
      "assertions": [
        {
          "type": "contains",
          "value": "Diff:"
        },
        {
          "type": "contains",
          "value": "Added"
        },
        {
          "type": "contains",
          "value": "Modified"
        },
        {
          "type": "contains",
          "value": "Removed"
        }
      ]
    },
    {
      "id": "normal-002",
      "name": "正常场景：JSON 导出格式",
      "description": "验证程序化导出功能",
      "input": {
        "arguments": "--from=INT-001 --to=current --export=json"
      },
      "expected_behavior": {
        "exports_json": true,
        "includes_structured_data": true
      },
      "assertions": [
        {
          "type": "file_exists",
          "value": "docs/ccc/diffs/*.json"
        }
      ]
    },
    {
      "id": "boundary-001",
      "name": "边界情况：无差异的制品",
      "description": "验证相同制品的对比",
      "input": {
        "arguments": "--from=BLP-001 --to=BLP-001"
      },
      "expected_behavior": {
        "detects_no_differences": true,
        "reports_identical": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "No differences"
        },
        {
          "type": "contains_any",
          "values": ["identical", "相同"]
        }
      ]
    },
    {
      "id": "error-001",
      "name": "错误处理：源制品不存在",
      "description": "验证不存在制品的处理",
      "input": {
        "arguments": "--from=BLP-999 --to=BLP-001"
      },
      "expected_behavior": {
        "shows_error": true,
        "suggests_listing_artifacts": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "not found"
        },
        {
          "type": "contains",
          "value": "/ccc:list"
        }
      ]
    },
    {
      "id": "error-002",
      "name": "错误处理：跨类型对比",
      "description": "验证不同类型制品的拒绝",
      "input": {
        "arguments": "--from=INT-001 --to=BLP-001"
      },
      "expected_behavior": {
        "rejects_type_mismatch": true,
        "explains_constraint": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "Cannot diff"
        },
        {
          "type": "contains",
          "value": "same artifact types"
        }
      ]
    }
  ],
  "test_fixtures": {
    "required_directories": ["docs/ccc/diffs/"],
    "required_files": [
      "test-fixtures/artifacts/BLP-001.yaml",
      "test-fixtures/artifacts/BLP-002.yaml",
      "test-fixtures/artifacts/INT-001.yaml"
    ],
    "cleanup_after_test": true
  },
  "coverage": {
    "normal_scenarios": 2,
    "boundary_scenarios": 1,
    "error_scenarios": 2,
    "total": 5
  }
}
