{
  "name": "cmd-status-trace-evals",
  "version": "1.0.0",
  "description": "测试用例：显示制品追溯历史",
  "test_cases": [
    {
      "id": "normal-001",
      "name": "正常场景：显示追溯历史",
      "description": "验证追溯历史显示",
      "input": {
        "arguments": "--artifact-id=BLP-001"
      },
      "expected_behavior": {
        "shows_trace": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "追溯"
        }
      ]
    },
    {
      "id": "error-001",
      "name": "错误处理：制品不存在",
      "description": "验证错误处理",
      "input": {
        "arguments": "--artifact-id=INVALID"
      },
      "expected_behavior": {
        "shows_error": true
      },
      "assertions": [
        {
          "type": "contains_any",
          "values": ["not found", "不存在"]
        }
      ]
    }
  ],
  "coverage": {
    "normal_scenarios": 1,
    "error_scenarios": 1,
    "total": 2
  }
}
