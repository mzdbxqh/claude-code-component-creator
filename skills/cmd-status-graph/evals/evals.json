{
  "name": "cmd-status-graph-evals",
  "version": "1.0.0",
  "description": "测试用例：可视化工作流图",
  "test_cases": [
    {
      "id": "normal-001",
      "name": "正常场景：生成工作流图",
      "description": "验证工作流可视化生成",
      "input": {
        "arguments": "--project-id=test-project"
      },
      "expected_behavior": {
        "generates_graph": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "工作流图"
        }
      ]
    },
    {
      "id": "error-001",
      "name": "错误处理：项目不存在",
      "description": "验证错误处理",
      "input": {
        "arguments": "--project-id=invalid"
      },
      "expected_behavior": {
        "shows_error": true
      },
      "assertions": [
        {
          "type": "contains_any",
          "values": ["not found", "不存在"]
        }
      ]
    }
  ],
  "coverage": {
    "normal_scenarios": 1,
    "error_scenarios": 1,
    "total": 2
  }
}
