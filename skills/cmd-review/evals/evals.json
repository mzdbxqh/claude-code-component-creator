{
  "version": "1.0",
  "skill": "cmd-review",
  "description": "测试组件质量审查流程的准确性和全面性",
  "evals": [
    {
      "name": "basic_component_review",
      "description": "基础审查：单个Skill组件质量检查",
      "input": {
        "target": "test-fixtures/sample-skill",
        "mode": "full"
      },
      "expected_output": {
        "report": {
          "file_pattern": "docs/reviews/.*-review\\.md",
          "contains_sections": [
            "执行摘要",
            "评估维度评分",
            "问题清单",
            "改进建议"
          ],
          "contains_scores": [
            "意图匹配",
            "配置和使用方法",
            "安全风险评估",
            "可测试性"
          ]
        },
        "validation": {
          "all_dimensions_checked": true,
          "issues_categorized": true,
          "fixes_suggested": true,
          "综合评分_range": [0, 100]
        }
      },
      "timeout": 180,
      "priority": "critical",
      "tags": ["review", "basic", "skill"]
    },
    {
      "name": "multi_component_review",
      "description": "全面审查：整个plugin项目质量检查",
      "input": {
        "target": "test-fixtures/sample-plugin",
        "include_architecture": true,
        "include_linkage": true
      },
      "expected_output": {
        "report": {
          "file_pattern": "docs/reviews/.*-comprehensive-review\\.md",
          "contains_sections": [
            "插件概述",
            "8维度评分",
            "架构分析",
            "链路验证",
            "问题清单"
          ],
          "min_components_reviewed": 5
        },
        "validation": {
          "architecture_analyzed": true,
          "circular_dependencies_checked": true,
          "linkage_validated": true
        }
      },
      "timeout": 300,
      "priority": "critical",
      "tags": ["review", "comprehensive", "architecture"]
    },
    {
      "name": "antipattern_detection",
      "description": "反模式检测：识别常见质量问题",
      "input": {
        "target": "test-fixtures/problematic-skill",
        "focus": ["security", "testability"]
      },
      "expected_output": {
        "issues": {
          "min_count": 3,
          "contains_codes": [
            "SEC-001",
            "TEST-001",
            "SCALE-001"
          ],
          "severity_levels": ["ERROR", "WARNING", "INFO"]
        },
        "validation": {
          "all_antipatterns_loaded": true,
          "detection_accurate": true,
          "fix_suggestions_provided": true
        }
      },
      "timeout": 120,
      "priority": "high",
      "tags": ["review", "antipattern", "detection"]
    },
    {
      "name": "plugin_manifest_validation",
      "description": "Plugin配置验证：plugin.json白名单schema检查",
      "input": {
        "target": "test-fixtures/plugin-with-invalid-manifest"
      },
      "expected_output": {
        "issues": {
          "contains_codes": ["PLUGIN-001"],
          "severity": "ERROR",
          "fix_provided": true
        },
        "validation": {
          "schema_loaded": true,
          "unknown_fields_detected": true,
          "whitelist_enforced": true
        }
      },
      "timeout": 60,
      "priority": "critical",
      "tags": ["review", "plugin", "manifest", "validation"]
    }
  ],
  "test_fixtures": {
    "components": [
      {
        "name": "sample-skill",
        "file": "test-fixtures/sample-skill/SKILL.md"
      },
      {
        "name": "sample-plugin",
        "dir": "test-fixtures/sample-plugin"
      },
      {
        "name": "problematic-skill",
        "file": "test-fixtures/problematic-skill/SKILL.md",
        "expected_issues": ["SEC-001", "TEST-001", "SCALE-001"]
      },
      {
        "name": "plugin-with-invalid-manifest",
        "dir": "test-fixtures/invalid-plugin",
        "expected_issues": ["PLUGIN-001"]
      }
    ]
  },
  "success_criteria": {
    "pass_rate": 0.75,
    "critical_pass_rate": 1.0,
    "max_avg_duration": 180,
    "antipattern_detection_accuracy": 0.95
  }
}
