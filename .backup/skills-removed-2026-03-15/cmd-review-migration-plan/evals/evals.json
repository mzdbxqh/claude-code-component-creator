{
  "name": "cmd-review-migration-plan-evals",
  "version": "1.0.0",
  "description": "测试用例：审查迁移计划",
  "test_cases": [
    {
      "id": "normal-001",
      "name": "正常场景：审查迁移计划",
      "description": "验证迁移计划审查",
      "input": {
        "arguments": "--plan=test-fixtures/plans/migration.md"
      },
      "expected_behavior": {
        "reviews_plan": true,
        "identifies_risks": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "审查"
        },
        {
          "type": "contains",
          "value": "迁移计划"
        }
      ]
    },
    {
      "id": "error-001",
      "name": "错误处理：计划不存在",
      "description": "验证错误处理",
      "input": {
        "arguments": "--plan=/invalid/path.md"
      },
      "expected_behavior": {
        "shows_error": true
      },
      "assertions": [
        {
          "type": "contains_any",
          "values": ["not found", "不存在"]
        }
      ]
    }
  ],
  "test_fixtures": {
    "required_files": ["test-fixtures/plans/migration.md"]
  },
  "coverage": {
    "normal_scenarios": 1,
    "error_scenarios": 1,
    "total": 2
  }
}
