{
  "name": "cmd-review-workflow-evals",
  "version": "1.0.0",
  "description": "测试用例：审查工作流定义",
  "test_cases": [
    {
      "id": "normal-001",
      "name": "正常场景：审查工作流",
      "description": "验证工作流审查",
      "input": {
        "arguments": "--workflow=test-fixtures/workflows/deploy.yaml"
      },
      "expected_behavior": {
        "reviews_workflow": true,
        "validates_steps": true
      },
      "assertions": [
        {
          "type": "contains",
          "value": "审查"
        },
        {
          "type": "contains",
          "value": "工作流"
        }
      ]
    },
    {
      "id": "error-001",
      "name": "错误处理：工作流不存在",
      "description": "验证错误处理",
      "input": {
        "arguments": "--workflow=/invalid/workflow.yaml"
      },
      "expected_behavior": {
        "shows_error": true
      },
      "assertions": [
        {
          "type": "contains_any",
          "values": ["not found", "不存在"]
        }
      ]
    }
  ],
  "test_fixtures": {
    "required_files": ["test-fixtures/workflows/deploy.yaml"]
  },
  "coverage": {
    "normal_scenarios": 1,
    "error_scenarios": 1,
    "total": 2
  }
}
