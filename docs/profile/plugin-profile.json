  "meta": {
    "name": "claude-code-component-creator",
    "display_name": "Claude Code Component Creator (CCC)",
    "version": "3.1.0",
    "description": "A powerful Claude Code plugin for creating high-quality components and skills with a structured Intent/Blueprint/Delivery workflow.",
    "positioning": "A powerful Claude Code plugin for creating high-quality components and skills with a structured Intent/Blueprint/Delivery workflow.",
    "base_framework": null,
    "repository": "https://github.com/mzdbxqh/claude-code-component-creator",
    "license": "MIT",
    "author": "mzdbxqh"
  },

  "architecture": {
    "component_types": {
      "skills": {
        "count": 25,
