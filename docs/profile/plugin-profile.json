          {
            "prefix": "cmd-",
            "count": 19,
            "description": "工作流命令 - 用户直接调用的斜杠命令",
            "examples": ["cmd-init", "cmd-design", "cmd-build", "cmd-review", "cmd-quick"]
          },
          {
            "prefix": "std-",
            "count": 4,
            "description": "标准规范 - 组件选型、命名、证据链等设计标准",
            "examples": ["std-component-selection", "std-naming-rules", "std-evidence-chain", "std-workflow-attribution"]
          },
          {
            "prefix": "lib-",
            "count": 2,
            "description": "知识库 - 反模式库、设计模式库",
            "examples": ["lib-antipatterns", "lib-design-patterns"]
          }
        ]
      },
      "agents": {
        "count": 46,
        "categories": [
          {
            "category": "reviewer",
            "count": 17,
            "description": "审查类 SubAgent - review-core, report-renderer, validator 等"
          },
          {
            "category": "advisor",
            "count": 6,
            "description": "咨询类 SubAgent - advisor-core, architect-core, planner-core 等"
          },
          {
            "category": "profiler",
            "count": 1,
            "description": "画像类 SubAgent - plugin-profiler"
          }
        ]
      },
      "commands": {
        "count": 0,
        "description": "命令定义（CCC 使用 Skills 代替 Commands）"
      },
      "hooks": {
        "count": 3,
        "types": ["SessionStart", "PreToolUse"],
        "description": "会话钩子和工具使用前钩子"
      }
    },

    "classification_system": {
      "primary": "role-based",
      "description": "基于组件角色分类：cmd-(用户命令) / std-(标准规范) / lib-(知识库)",
      "rationale": "角色分类比技术分层更符合组件的实际用途，便于用户快速定位功能"
    },

    "workflow_mechanism": {
      "type": "three-stage",
      "stages": [
        {
          "name": "Intent",
          "command": "/ccc:init",
          "description": "创建意图制品，使用 4 问题框架澄清需求",
          "output": "intent-*.yaml"
        },
        {
          "name": "Blueprint",
          "command": "/ccc:design",
          "description": "生成蓝图，5 阶段设计流程（需求→架构→设计→验证→规划）",
          "output": "blueprint-*.yaml"
        },
        {
          "name": "Delivery",
          "command": "/ccc:build",
          "description": "构建交付物，生成 SKILL.md、代码、测试和文档",
          "output": "delivery-*.yaml + 完整组件包"
        }
      ],
      "activation": {
        "manual": {
          "type": "slash_commands",
          "commands": ["/ccc:init", "/ccc:design", "/ccc:build", "/ccc:review", "/ccc:quick"],
          "description": "用户通过斜杠命令手动调用工作流各阶段"
        },
        "automatic": {
          "type": "SessionStart hook",
          "trigger": "检测到工作流状态文件（.ccc/artifacts/*.yaml）",
          "behavior": "自动加载相关 Skills 和 SubAgents",
          "enforcement": false
        }
      }
    }
  },

  "usage": {
    "slash_commands": [
      {"command": "/ccc:init", "skill": "cmd-init", "description": "创建意图制品", "category": "workflow"},
      {"command": "/ccc:design", "skill": "cmd-design", "description": "生成蓝图", "category": "workflow"},
      {"command": "/ccc:build", "skill": "cmd-build", "description": "构建交付物", "category": "workflow"},
      {"command": "/ccc:implement", "skill": "cmd-implement", "description": "实施迭代计划", "category": "workflow"},
      {"command": "/ccc:review", "skill": "cmd-review", "description": "质量审查（76+ 检查项）", "category": "quality"},
      {"command": "/ccc:quick", "skill": "cmd-quick", "description": "快速完整工作流", "category": "workflow"},
      {"command": "/ccc:iterate", "skill": "cmd-iterate", "description": "迭代蓝图", "category": "workflow"},
      {"command": "/ccc:design-iterate", "skill": "cmd-design-iterate", "description": "迭代现有组件", "category": "workflow"},
      {"command": "/ccc:status", "skill": "cmd-status", "description": "显示项目状态", "category": "utility"},
      {"command": "/ccc:trace", "skill": "cmd-trace", "description": "生成追溯矩阵", "category": "quality"},
      {"command": "/ccc:validate", "skill": "cmd-validate", "description": "外部工具验证", "category": "quality"}
    ],
    "auto_activation_skills": [
      {
        "skill": "lib-antipatterns",
        "trigger": "审查流程需要反模式检测",
        "loaded_by": ["cmd-review", "review-core"]
      },
      {
        "skill": "lib-design-patterns",
        "trigger": "设计流程需要模式参考",
        "loaded_by": ["cmd-design", "blueprint-core"]
      }
    ]
  },

  "philosophy": {
    "core_principles": [
      {
        "principle": "外部状态管理",
        "description": "工作流状态存储在 YAML 文件而非会话中",
        "rationale": "确保可中断、可恢复、可审计",
        "implementation": ".ccc/artifacts/ 目录下的 YAML 制品文件",
        "benefit": "支持长时间工作流，状态可持久化和版本控制"
      },
      {
        "principle": "完整追溯性",
        "description": "从需求到实现的每一步都有清晰的追溯链",
        "rationale": "确保需求不丢失，设计有依据",
        "implementation": "Intent → Blueprint → Delivery 的完整追溯矩阵",
        "benefit": "质量可追溯，问题可定位"
      },
      {
        "principle": "双模型验证",
        "description": "Sonnet 生成，Haiku 验证",
        "rationale": "平衡生成质量和验证成本",
        "implementation": "生成阶段使用 Sonnet，验证阶段使用 Haiku",
        "benefit": "高质量输出 + 低成本验证"
      },
      {
        "principle": "元反思框架",
        "description": "4 维度自我评估（完整性、一致性、可测试性、可维护性）",
        "rationale": "确保设计质量，减少返工",
        "implementation": "Blueprint 阶段的 Meta-Reflection 检查",
        "benefit": "设计时发现问题，而非实施后返工"
      },
      {
        "principle": "测试驱动开发",
        "description": "测试先于实现",
        "rationale": "确保代码可测试，需求可验证",
        "implementation": "Delivery 阶段强制生成测试用例",
        "benefit": "代码质量有保障，回归测试有基础"
      },
      {
        "principle": "YAGNI",
        "description": "你不会需要它 - 只实现当前需要的功能",
        "rationale": "避免过度设计，降低复杂度",
        "implementation": "Intent 阶段明确排除不需要的功能",
        "benefit": "代码简洁，维护成本低"
      },
      {
        "principle": "DRY",
        "description": "不要重复自己 - 复用设计和代码",
        "rationale": "减少冗余，提升一致性",
        "implementation": "std- 和 lib- Skills 提供可复用的标准和知识",
        "benefit": "统一标准，降低学习成本"
      }
    ]
  },

