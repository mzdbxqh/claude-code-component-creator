      "steps": [
        "调用 init-transaction.sh",
        "验证 checkpoint 文件创建",
        "验证数据目录创建",
        "验证 JSON 格式正确"
      ],
      "assertions": [
        "checkpoint_file_exists",
        "data_directory_exists",
        "checkpoint_json_valid",
        "transaction_id_format_correct"
      ],
      "expected_duration": "< 100ms"
    },
    {
